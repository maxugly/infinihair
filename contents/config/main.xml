<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
                          http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>
  <group name="">
    <!--
      Primary crosshair: LineColor + width/opacity/ticks.
      Secondary offset guides: each axis has enable + offset(px) + color.
      Color keys use KColorButton; R/G/B mirrors written by the disk poller.
    -->
    <entry name="LineColor" type="Color">
      <label>Primary line color</label>
      <default>#FF0000</default>
    </entry>
    <entry name="LineWidth" type="Int">
      <default>1</default>
      <min>1</min>
      <max>32</max>
    </entry>
    <entry name="Opacity" type="Double">
      <default>0.8</default>
      <min>0.05</min>
      <max>1.0</max>
    </entry>
    <entry name="ShowInchTicks" type="Bool">
      <default>true</default>
    </entry>
    <entry name="ScreenDiagonalInches" type="Double">
      <label>Physical screen diagonal in inches (used with detected resolution to compute PPI)</label>
      <default>27.0</default>
      <min>5.0</min>
      <max>120.0</max>
    </entry>
    <entry name="TickLength" type="Int">
      <label>Length of major inch tick marks in pixels</label>
      <default>10</default>
      <min>2</min>
      <max>64</max>
    </entry>
    <entry name="ShowHalfInchTicks" type="Bool">
      <default>true</default>
    </entry>

    <entry name="OffsetVerticalEnabled" type="Bool">
      <label>Show second vertical guide</label>
      <default>false</default>
    </entry>
    <entry name="OffsetVerticalOffset" type="Int">
      <label>Second vertical offset from cursor (px; negative = left)</label>
      <default>100</default>
      <min>-4000</min>
      <max>4000</max>
    </entry>
    <entry name="OffsetVerticalColor" type="Color">
      <label>Second vertical line color</label>
      <default>#00FFFF</default>
    </entry>

    <entry name="OffsetHorizontalEnabled" type="Bool">
      <label>Show second horizontal guide</label>
      <default>false</default>
    </entry>
    <entry name="OffsetHorizontalOffset" type="Int">
      <label>Second horizontal offset from cursor (px; negative = up)</label>
      <default>100</default>
      <min>-4000</min>
      <max>4000</max>
    </entry>
    <entry name="OffsetHorizontalColor" type="Color">
      <label>Second horizontal line color</label>
      <default>#00FF00</default>
    </entry>

    <entry name="AutoOffsetOnMove" type="Bool">
      <label>While moving or resizing a window, set guide offsets to nearest frame edges</label>
      <default>true</default>
    </entry>
  </group>
</kcfg>
